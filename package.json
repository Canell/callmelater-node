{
  "name": "callmelater",
  "version": "0.3.0",
  "description": "Official Node.js SDK for CallMeLater — schedule durable HTTP calls and interactive reminders",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "callmelater",
    "scheduler",
    "deferred",
    "http",
    "reminder",
    "webhook",
    "cron",
    "delayed",
    "queue"
  ],
  "author": "CallMeLater",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Canell/callmelater-node.git"
  },
  "homepage": "https://callmelater.io",
  "bugs": {
    "url": "https://github.com/Canell/callmelater-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
