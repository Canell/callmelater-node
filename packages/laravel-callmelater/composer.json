{
    "name": "callmelater/laravel",
    "description": "Laravel SDK for CallMeLater - Schedule HTTP calls and interactive reminders",
    "keywords": ["laravel", "callmelater", "scheduler", "reminders", "webhooks", "deferred"],
    "license": "MIT",
    "authors": [
        {
            "name": "CallMeLater",
            "email": "support@callmelater.io"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "CallMeLater\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CallMeLater\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CallMeLater\\Laravel\\CallMeLaterServiceProvider"
            ],
            "aliases": {
                "CallMeLater": "CallMeLater\\Laravel\\Facades\\CallMeLater"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
