APP_NAME=CallMeLater
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=callmelater
DB_USERNAME=callmelater
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=postmark
MAIL_FROM_ADDRESS="reminders@callmelater.com"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark API Token (get from https://postmarkapp.com)
POSTMARK_TOKEN=

# Brevo SMS (get from https://app.brevo.com/settings/keys/api)
BREVO_SMS_ENABLED=false
BREVO_API_KEY=
BREVO_SMS_SENDER=CallMeLater

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_APP_DOMAIN=callmelater.io

# CallMeLater Server Settings
CALLMELATER_OUTBOUND_IP=51.159.42.123

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Monthly prices
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
# Annual prices (2 months free: Pro=€190/yr, Business=€790/yr)
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# Domain configuration (for subdomains like docs.domain.test, status.domain.test)
APP_DOMAIN=callmelater.io

# Google reCAPTCHA v3 (get from https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"
